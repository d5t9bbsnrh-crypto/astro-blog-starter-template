---
---

<html lang="en">
  <head>
    <title>RLT Music and Film Works</title>
    <meta name="description" content="RLT Music and Film Works - Music, Film, Artists, Production, and Entertainment Services." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body>
    <header class="hero">
      <nav>
        <h2>RLT Music & Film Works</h2>
        <div>
          <a href="#artists">Artists</a>
          <a href="#music">Music</a>
          <a href="#film">Film</a>
          <a href="#store">Store</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>

      <section class="hero-content">
        <h1>RLT Music and Film Works</h1>
        <p>Music • Film • Production • Entertainment</p>
        <h3>New Single Coming 2026</h3>
        <a class="btn" href="#contact">Work With Us</a>
      </section>
    </header>

    <main>
      <section id="about">
        <h2>About RLT</h2>
        <p>
          RLT Music and Film Works is an entertainment company focused on music production,
          artist development, film projects, creative media, merchandising, and live entertainment.
        </p>
      </section>

      <section id="artists" class="cards">
        <h2>Artists</h2>
        <div class="grid">
          <div class="card">
            <h3>Featured Artists</h3>
            <p>Artist showcases, releases, visuals, and promotional campaigns.</p>
          </div>
          <div class="card">
            <h3>Ozone</h3>
            <p>Dedicated artist page, music releases, videos, and brand content.</p>
          </div>
          <div class="card">
            <h3>Artist Development</h3>
            <p>Creative direction, recording, branding, performance support, and promotion.</p>
          </div>
        </div>
      </section>

      <section id="music" class="dark">
        <h2>Music</h2>
        <p>
          Original music, singles, albums, downloads, CDs, vinyl, streaming links,
          and future releases from the RLT catalog.
        </p>
      </section>

      <section id="film">
        <h2>Film Works</h2>
        <p>
          Film production, music videos, promotional visuals, documentary projects,
          and creative storytelling for artists and brands.
        </p>
      </section>

      <section id="store" class="cards">
        <h2>Store & Partners</h2>
        <div class="grid">
          <div class="card">
            <h3>Music Store</h3>
            <p>Digital downloads, CDs, vinyl, and exclusive releases.</p>
          </div>
          <div class="card">
            <h3>Merchandise</h3>
            <p>RLT apparel, artist merchandise, and limited-edition items.</p>
          </div>
          <div class="card">
            <h3>Subsidiary Partners</h3>
            <p>Big T Entertainment and creative brand partners.</p>
          </div>
        </div>
      </section>

      <section id="contact" class="contact">
        <h2>Contact</h2>
        <p>RLT Music and Film Works</p>
        <p>10134 6th Street Suite H, Rancho Cucamonga, CA 91730</p>
        <p>Tel: (219) 201-6827</p>
      </section>
    </main>

    <footer>
      <p>© 2026 RLT Music and Film Works. All Rights Reserved.</p>
    </footer>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #111;
    color: #fff;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 8%;
    background: rgba(0, 0, 0, 0.65);
  }

  nav h2 {
    color: #d4af37;
    margin: 0;
  }

  nav a {
    color: white;
    text-decoration: none;
    margin-left: 20px;
    font-weight: bold;
  }

  nav a:hover {
    color: #d4af37;
  }

  .hero {
    min-height: 90vh;
    background:
      linear-gradient(rgba(0,0,0,.65), rgba(0,0,0,.85)),
      radial-gradient(circle at center, #444 0%, #111 70%);
  }

  .hero-content {
    text-align: center;
    padding: 150px 20px;
  }

  .hero-content h1 {
    font-size: 60px;
    color: #d4af37;
    margin-bottom: 15px;
  }

  .hero-content p {
    font-size: 24px;
    letter-spacing: 2px;
  }

  .hero-content h3 {
    font-size: 28px;
    margin-top: 30px;
  }

  .btn {
    display: inline-block;
    margin-top: 25px;
    padding: 14px 30px;
    background: #d4af37;
    color: #111;
    text-decoration: none;
    font-weight: bold;
    border-radius: 30px;
  }

  section {
    padding: 70px 10%;
    text-align: center;
  }

  section h2 {
    color: #d4af37;
    font-size: 36px;
  }

  section p {
    font-size: 18px;
    line-height: 1.7;
    max-width: 850px;
    margin: auto;
  }

  .dark {
    background: #000;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    margin-top: 35px;
  }

  .card {
    background: #1c1c1c;
    padding: 30px;
    border: 1px solid #333;
    border-radius: 14px;
  }

  .card h3 {
    color: #d4af37;
  }

  .contact {
    background: #181818;
  }

  footer {
    text-align: center;
    padding: 25px;
    background: #000;
    color: #aaa;
  }

  @media (max-width: 800px) {
    nav {
      flex-direction: column;
    }

    nav a {
      display: inline-block;
      margin: 10px;
    }

    .hero-content h1 {
      font-size: 38px;
    }

    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
