<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RLT Music and Film Works</title>

    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(to bottom, #1a1a1a, #3a3a3a);
        color: white;
      }

      header {
        text-align: center;
        padding: 80px 20px;
      }

      header img {
        max-width: 320px;
        width: 100%;
      }

      h1 {
        font-size: 3rem;
        margin-top: 20px;
      }

      p {
        font-size: 1.2rem;
        color: #d0d0d0;
      }

      nav {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 30px;
      }

      nav a {
        color: #ffd700;
        text-decoration: none;
        font-weight: bold;
      }

      .hero {
        text-align: center;
        padding: 60px 20px;
      }

      .hero h2 {
        font-size: 2rem;
      }

      footer {
        text-align: center;
        padding: 40px 20px;
        color: #999;
      }
    </style>
  </head>

  <body>
    <header>
      <img src="/logo.png" alt="RLT Logo" />

      <h1>RLT Music and Film Works</h1>

      <p>
        Music • Film • Entertainment • Creative Media
      </p>

      <nav>
        <a href="/">Home</a>
        <a href="/artists">Artists</a>
        <a href="/store">Store</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>

    <section class="hero">
      <h2>New Single Coming 2026</h2>

      <p>
        Official music releases, artist features, film projects,
        and entertainment media.
      </p>
    </section>

    <footer>
      © 2026 RLT Music and Film Works
    </footer>
  </body>
</html>
