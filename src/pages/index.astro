<html lang="en">
  <head>
    <title>RLT Music and Film Works</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <h1>RLT Music and Film Works</h1>
        <p>Music • Film • Artist Development • Entertainment Production</p>
        <a href="#contact" class="button">Contact Us</a>
      </section>

      <section class="content">
        <h2>Welcome to RLT</h2>
        <p>
          RLT Music and Film Works supports artists, music projects, film production,
          creative branding, and entertainment business development.
        </p>
      </section>

      <section id="contact" class="content">
        <h2>Contact</h2>
        <p>10134 6th Street Suite H, Rancho Cucamonga, CA 91730</p>
        <p>Tel: (219) 201-6827</p>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #f4f1ec;
    color: #111;
  }

  .page {
    min-height: 100vh;
  }

  .hero {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #111, #3b2a12, #c59b3c);
    color: white;
    text-align: center;
    padding: 40px 20px;
  }

  h1 {
    font-size: 52px;
    margin: 0 0 15px;
    letter-spacing: 2px;
  }

  .hero p {
    font-size: 22px;
    margin-bottom: 30px;
  }

  .button {
    background: #c59b3c;
    color: #111;
    padding: 14px 28px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: bold;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 50px 25px;
    text-align: center;
  }

  .content h2 {
    font-size: 32px;
    margin-bottom: 15px;
  }

  .content p {
    font-size: 18px;
    line-height: 1.6;
  }
</style>
